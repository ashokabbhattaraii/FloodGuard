# Frontend — Next.js (NEXT_PUBLIC_* are inlined at BUILD time)
# Copy this to .env.local and fill in values

# Backend API URL
# Local development:
NEXT_PUBLIC_API_URL=http://localhost:5001/api
# Production (set before running `bun run build`):
# NEXT_PUBLIC_API_URL=https://floodguard-backend-env.eba-xxxx.ap-southeast-1.elasticbeanstalk.com/api

# Supabase (if using Supabase auth on frontend)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key
