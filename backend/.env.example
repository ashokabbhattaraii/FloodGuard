# Application
PORT=5001
NODE_ENV=development

# Database (PostgreSQL)
# Local development:
DATABASE_URL="postgresql://postgres@localhost:5432/floodguard"
# AWS RDS (production):
# DATABASE_URL="postgresql://floodguard:YOUR_PASSWORD@floodguard-db.xxxx.ap-southeast-1.rds.amazonaws.com:5432/postgres?schema=public"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d

# CORS — set to your frontend URL
FRONTEND_URL=http://localhost:3000

# AWS
AWS_REGION=ap-southeast-1
S3_BUCKET=floodguard-uploads

# SNS / SES (Phase 6 — alerts)
SNS_TOPIC_ARN=arn:aws:sns:ap-southeast-1:ACCOUNT_ID:floodguard-alerts
SES_FROM_EMAIL=alerts@yourdomain.com

# Weather & Geocoding (all free, no API keys needed)
# Open-Meteo: https://open-meteo.com/
# OpenStreetMap Nominatim: https://nominatim.openstreetmap.org/
